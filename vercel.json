{
  "version": 2,
  "routes": [
    { "src": "/shopboost.js", "dest": "/public/shopboost.js" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/shopboost.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    }
  ]
}
